<!doctype html>
<html lang="en">
  <body style="font-family: Arial, sans-serif; color: #1f2937; line-height: 1.5;">
    <h2 style="margin: 0 0 12px 0;">Recover your password</h2>
    <p>Hello <strong>{{ username }}</strong>,</p>
    <p>We received a request to reset your password.</p>
    <p>
      Use this code to continue:
      <strong style="font-size: 18px; letter-spacing: 2px;">{{ recovery_code }}</strong>
    </p>
    <p>This code expires in {{ expires_minutes }} minutes.</p>
    <p>If you did not request a password recovery, ignore this email.</p>
    <hr style="margin: 20px 0; border: none; border-top: 1px solid #e5e7eb;" />
    <p style="font-size: 12px; color: #6b7280;">Security note: never share this code with anyone.</p>
  </body>
</html>
