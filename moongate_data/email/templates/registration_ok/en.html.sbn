<!doctype html>
<html lang="en">
  <body style="font-family: Arial, sans-serif; color: #1f2937; line-height: 1.5;">
    <h2 style="margin: 0 0 12px 0;">Registration completed</h2>
    <p>Hello <strong>{{ username }}</strong>,</p>
    <p>Your account has been created successfully on <strong>Moongate</strong>.</p>
    <p>You can now log in and start playing.</p>
    <hr style="margin: 20px 0; border: none; border-top: 1px solid #e5e7eb;" />
    <p style="font-size: 12px; color: #6b7280;">If you did not request this account, please ignore this email.</p>
  </body>
</html>
