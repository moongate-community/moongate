{
  "UODirectory": "~/uo",
  "LogLevel": "Information",
  "LogPacketData": false,
  "IsDeveloperMode": false,
  "Http": {
    "IsEnabled": true,
    "Port": 8088,
    "WebsiteUrl": "http://localhost",
    "IsOpenApiEnabled": true,
    "Jwt": {
      "IsEnabled": true,
      "SigningKey": null,
