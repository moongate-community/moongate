  "Email": {
    "IsEnabled": false,
    "FromAddress": "no-reply@moongate.local",
    "FallbackLocale": "en",
    "Smtp": {
      "Host": null,
      "Port": 587,
      "UseSsl": true,
      "Username": null,
      "Password": null
    }
