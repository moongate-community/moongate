{
  "schema": "moongate.startup.genders.v1",
  "rules": [
    {
      "match": {
        "gender": "male"
      },
      "add": {
        "equip": [
          {
            "templateId": "LongPants"
          }
        ]
      }
    },
    {
      "match": {
        "gender": "female"
      },
      "add": {
        "equip": [
          {
            "templateId": "Skirt"
          }
        ]
      },
      "remove": {
        "equip": [
          "LongPants"
        ]
      }
    }
  ]
}
