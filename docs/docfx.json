{
  "metadata": [
    {
      "src": [
        {
          "files": ["src/**/*.csproj"],
          "src": ".."
        }
      ],
      "dest": "api",
      "properties": { "TargetFramework": "net10.0" }
    }
  ],
  "build": {
    "content": [
      { "files": ["**/*.{md,yml}"], "exclude": ["_site/**", "templates/**", "obj/**"] }
    ],
    "resource": [
      { "files": ["images/**"] }
    ],
    "output": "_site",
    "template": ["default", "modern", "templates/moongate"],
    "globalMetadata": {
      "_appName": "Moongate",
      "_appTitle": "Moongate",
      "_appLogoPath": "images/logo.png",
      "_appFooter": "Moongate — an Ultima Online server emulator",
      "_enableSearch": true,
      "_disableContribution": true
    },
    "sitemap": { "baseUrl": "https://moongate-community.github.io/moongate" }
  }
}
